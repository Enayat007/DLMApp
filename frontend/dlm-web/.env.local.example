# Copy this file to .env.local and fill in values

# Base URL for the .NET backend API
# NEXT_PUBLIC_API_URL=https://api.nibrasgroups.com
 NEXT_PUBLIC_API_URL=https://localhost:54172

# Base domain for auth cookie — must match the root domain so the cookie is
# accessible on all tenant subdomains (e.g. acme.localhost, beta.localhost).
# In production set this to your root domain: nibrasgroups.com
NEXT_PUBLIC_COOKIE_DOMAIN=localhost
